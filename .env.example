# LongPort OpenAPI 配置示例
# 复制此文件为 .env 并填入真实的API凭据

# LongPort API 凭据 (从 LongPort 开发者中心获取)
LONGPORT_APP_KEY=your_app_key_here
LONGPORT_APP_SECRET=your_app_secret_here
LONGPORT_ACCESS_TOKEN=your_access_token_here

# 可选配置
LONGPORT_REGION=hk          # cn (中国大陆) 或 hk (香港)
LONGPORT_ENABLE_OVERNIGHT=true  # 启用隔夜行情

# 其他现有配置...
# GEMINI_API_KEY=your_gemini_key_here