# 复制此文件为 .env 并填入真实的API凭据

# --- Long Bridge API ---

GEMINI_API_KEY=your_gemini_key_here

# 选填，用于并发Gemini模型调用

GEMINI_API_KEY_2=your_gemini_key_2_here
GEMINI_API_KEY_3=your_gemini_key_3_here

# --- Long Bridge API ---

# 配置地区
LONGPORT_REGION=hk

# 启用隔夜行情
LONGPORT_ENABLE_OVERNIGHT=true

# 账户相关设置
LONGPORT_APP_KEY=your_app_key_here
LONGPORT_APP_SECRET=your_app_secret_here

# 实盘账户 / 测试账户
LONGPORT_ACCESS_TOKEN=your_real_access_token_here
LONGPORT_ACCESS_TOKEN_TEST=your_test_access_token_here

# 可选：指定默认环境
LONGPORT_DEFAULT_ENV=test    # test | real