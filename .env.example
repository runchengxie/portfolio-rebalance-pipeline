# LongPort OpenAPI 配置示例
# 复制此文件为 .env 并填入真实的API凭据

# LongPort API 基础配置
LONGPORT_REGION=hk
LONGPORT_APP_KEY=your_app_key_here
LONGPORT_APP_SECRET=your_app_secret_here

# 新旧并存，优先读 TEST/REAL
# TEST对应测试账户，REAL对应真实账户
LONGPORT_ACCESS_TOKEN_TEST=your_test_access_token_here
LONGPORT_ACCESS_TOKEN_REAL=your_real_access_token_here
# 兼容旧值（仅当上面两个都没配时才用）
LONGPORT_ACCESS_TOKEN=your_access_token_here

# 可选：指定默认环境
LONGPORT_DEFAULT_ENV=test    # test | real

# 其他可选配置
LONGPORT_ENABLE_OVERNIGHT=true  # 启用隔夜行情

# 其他现有配置...
# GEMINI_API_KEY=your_gemini_key_here