# --- OS-specific files ---
# Ignore macOS and Windows system files that can clutter the repo.
.DS_Store
Thumbs.db

# --- Python & Jupyter Specific ---
# Byte-code and cache
__pycache__/
*.pyc

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Virtual environments (common patterns)
.venv/
venv/
env/
stock-analysis-env/

# Build artifacts and packaging
build/
dist/
*.egg-info/

# --- Project-specific ---
# Data files
data/

# Generated output files
outputs/

# Debugging or temporary files
full_project_source.txt

# --- Generated Documents ---
# Ignore binary/compiled document formats. Track the source (.md, .tex) instead.
*.pdf
*.docx
*.xlsx

# --- R & RStudio Specific ---
.Rhistory
.RData
.Rprofile
.Rproj.user/
renv/