# .gitignore

# --- R & RStudio Specific ---
# Workspace history and data files, not needed for reproducibility.
.Rhistory
.RData
.Rprofile

# RStudio project-specific temporary files and settings.
.Rproj.user/

# --- renv (R Package Management) ---
# The local library of packages. This is recreated using the renv.lock file.
renv/

# --- Python & Jupyter Specific ---
# Byte-code and cache
__pycache__/
*.pyc

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Virtual environments (common patterns)
.venv/
venv/
env/
stock-analysis-env/

# Build artifacts
build/
dist/
*.egg-info/

# Data folder
/data/

# --- Generated Documents and files ---
# Ignore binary/compiled document formats. Track the source files (e.g., .md) instead.
docs/*.pdf
docs/*.docx
dynamic_multi_year_ranked_stocks.xlsx
portfolio_performance.png

# --- OS-specific files ---
# Ignore macOS and Windows system files that can clutter the repo.
.DS_Store
Thumbs.db

# --- Debugging purpose ---
full_project_source.txt